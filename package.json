{
  "name": "tajfix-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @tajfix/client",
    "dev:client": "npm run dev -w @tajfix/client",
    "dev:master": "npm run dev -w @tajfix/master",
    "dev:seller": "npm run dev -w @tajfix/seller",
    "dev:admin": "npm run dev -w @tajfix/admin",
    "build": "npm run build -w @tajfix/client && npm run build -w @tajfix/master && npm run build -w @tajfix/seller && npm run build -w @tajfix/admin",
    "build:client": "npm run build -w @tajfix/client",
    "build:master": "npm run build -w @tajfix/master",
    "build:seller": "npm run build -w @tajfix/seller",
    "build:admin": "npm run build -w @tajfix/admin",
    "lint": "npm run lint -w @tajfix/client",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.1.0",
    "@prisma/client": "^5.17.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.463.0",
    "next": "14.2.5",
    "next-auth": "^4.24.11",
    "prisma": "^5.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.50.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.4"
  }
}
