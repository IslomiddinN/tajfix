generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  MASTER
  SELLER
}

enum CategoryType {
  SERVICE
  PRODUCT
}

enum OrderStatus {
  NEW
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SupportStatus {
  OPEN
  CLOSED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String    @unique
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cartItems    CartItem[]
  productOrders ProductOrder[]
  repairBookings RepairBooking[]
  reviews      Review[]
  masterProfile Master?
  sellerProfile Seller?
  supportThread SupportThread?
  addresses     Address[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]
}

model Category {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  type      CategoryType
  icon      String
  createdAt DateTime     @default(now())
  services  Service[]    @relation("CategoryServices")
  products  Product[]    @relation("CategoryProducts")
}

model Service {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  description     String
  priceFrom       Int
  category        Category  @relation(fields: [categoryId], references: [id], name: "CategoryServices")
  categoryId      String
  imageUrl        String
  isUrgentAvailable Boolean @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  repairBookings  RepairBooking[]
}

model Master {
  id           String   @id @default(cuid())
  name         String
  phone        String
  avatarUrl    String
  specialization String
  description  String
  rating       Float
  reviewsCount Int
  distanceKm   Float
  priceFrom    Int
  guaranteeText String
  isAvailable  Boolean  @default(true)
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  bookings     RepairBooking[]
  reviews      Review[]
}

model Seller {
  id          String    @id @default(cuid())
  shopName    String
  description String    @default("")
  logoUrl     String    @default("")
  phone       String
  isApproved  Boolean   @default(true)
  user        User      @relation(fields: [userId], references: [id])
  userId      String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  description     String
  brand           String
  category        Category  @relation(fields: [categoryId], references: [id], name: "CategoryProducts")
  categoryId      String
  seller          Seller?   @relation(fields: [sellerId], references: [id])
  sellerId        String?
  price           Int
  oldPrice        Int?
  discountPercent Int?
  imageUrl        String
  rating          Float
  stock           Int
  isHit           Boolean  @default(false)
  isNew           Boolean  @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  cartItems       CartItem[]
  orderItems      ProductOrderItem[]
  reviews         Review[]
}

model CartItem {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id])
  userId    String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int     @default(1)
}

model ProductOrder {
  id          String              @id @default(cuid())
  user        User                @relation(fields: [userId], references: [id])
  userId      String
  totalAmount Int
  status      OrderStatus         @default(NEW)
  address     String
  phone       String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       ProductOrderItem[]
}

model ProductOrderItem {
  id        String   @id @default(cuid())
  order     ProductOrder @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  price     Int
  fulfilled Boolean  @default(false)
}

model RepairBooking {
  id             String    @id @default(cuid())
  user           User      @relation(fields: [userId], references: [id])
  userId         String
  service        Service   @relation(fields: [serviceId], references: [id])
  serviceId      String
  master         Master?   @relation(fields: [masterId], references: [id])
  masterId       String?
  problemText    String
  address        String
  phone          String
  preferredDate  DateTime
  status         OrderStatus @default(NEW)
  estimatedPrice Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  master    Master?  @relation(fields: [masterId], references: [id])
  masterId  String?
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

// Чат поддержки: один тред на пользователя, сообщения внутри треда.
model SupportThread {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String           @unique
  status    SupportStatus    @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  SupportMessage[]
}

model SupportMessage {
  id          String        @id @default(cuid())
  thread      SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId    String
  body        String
  // false — сообщение от клиента, true — ответ поддержки/админа.
  fromSupport Boolean       @default(false)
  createdAt   DateTime      @default(now())

  @@index([threadId])
}

// Уведомления в приложении. type: order | booking | support | sale | system.
model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String   @default("system")
  title     String
  body      String   @default("")
  link      String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// Подписки браузера на web-push (по одной на устройство/браузер).
model PushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Адреса доставки пользователя.
model Address {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  label     String   @default("")
  address   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
