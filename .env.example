# Скопируйте в .env и заполните своими значениями
NEXTAUTH_URL="http://localhost:3000"
# Сгенерируйте: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/tajfix?schema=public"

# Публичный адрес сайта (для SEO, sitemap, OG-картинок).
# В проде укажите ваш домен, например https://tajfix.tj
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Уведомления о новых заказах/заявках в Telegram (опционально).
# Создайте бота через @BotFather, узнайте chat_id через @userinfobot.
# Если оставить пустыми — уведомления просто не отправляются.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
